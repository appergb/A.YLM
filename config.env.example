# A.YLM 项目环境变量配置示例
# 复制此文件为 config.env 并根据需要修改配置

# SHARP模型相关路径
SHARP_MODEL_PATH=models/sharp_2572gikvuh.pt

# 体素化工具输出路径配置
VOXELIZER_INTERMEDIATE_DIR=outputs/output_gaussians/cropped_pointclouds

# SHARP模型预加载标志
SHARP_MODEL_PRELOADED=0

# 输入输出目录（可选，用于覆盖默认路径）
INPUT_DIR=inputs/input_images
OUTPUT_DIR=outputs/output_gaussians
